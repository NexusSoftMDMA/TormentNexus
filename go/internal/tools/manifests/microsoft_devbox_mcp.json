    {
      "tool_name": "start_devbox",
      "handler_func": "HandleStartDevBox",
      "description": "Starts a Dev Box instance"
    },
    {
      "tool_name": "stop_devbox",
      "handler_func": "HandleStopDevBox",
      "description": "Stops a Dev Box instance"
    }
  ]
