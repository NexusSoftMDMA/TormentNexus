{
  "name": "mcp-gen",
  "version": "2.0.0",
  "description": "OpenAPI → MCP Server generator CLI",
  "main": "dist/index.js",
  "bin": {
    "mcp-gen": "dist/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ChristopherDond/MCP-Generator"
  },
  "scripts": {
    "build": "tsc && npm run copy-templates",
    "copy-templates": "xcopy /E /I /Y src\\templates dist\\templates",
    "dev": "ts-node --prefer-ts-exts src/cli/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "release": "npm run build && npm run test && node scripts/release.js",
    "release:patch": "npm run build && npm run test && npm version patch && git push origin main --tags",
    "release:rc": "npm run build && npm run test && npm version prerelease --preid=rc && git push origin main --tags"
  },
  "keywords": ["mcp", "openapi", "generator", "cli"],
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "handlebars": "^4.7.8",
    "ora": "^8.0.1"
    ,"inquirer": "^9.2.0"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/inquirer": "^9.0.8",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}