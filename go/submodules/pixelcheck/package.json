{
  "name": "pixelcheck",
  "version": "1.3.0",
  "mcpName": "io.github.xcodethink/pixelcheck",
  "description": "MCP-first browser primitives for AI agents — real eyes and hands on the web. Local-first. Vendor-agnostic. Yours to own.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pixelcheck": "dist/cli.js",
    "pixelcheck-mcp": "dist/mcp/server.js"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "files": [
    "dist/",
    "scripts/postinstall.mjs",
    "docs/schemas/",
    "personas/",
    "scenarios/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcodethink/pixelcheck.git"
  },
  "bugs": {
    "url": "https://github.com/xcodethink/pixelcheck/issues"
  },
  "homepage": "https://github.com/xcodethink/pixelcheck#readme",
  "scripts": {
    "build": "tsc",
    "postinstall": "node scripts/postinstall.mjs",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "tsc --noEmit",
    "audit": "tsx src/cli.ts",
    "test": "npm run lint:no-console && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "vitest run --coverage --coverage.thresholdAutoUpdate=false",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:playwright": "playwright test",
    "test:e2e:replay": "AUDIT_E2E_REPLAY=1 vitest run tests/integration/llm-cassettes.test.ts --no-file-parallelism",
    "test:e2e:record": "AUDIT_E2E_RECORD=1 vitest run tests/integration/llm-cassettes.test.ts --no-file-parallelism",
    "bench": "vitest bench --run --outputJson=docs/perf-current.json",
    "bench:check": "tsx scripts/check-perf.ts",
    "bench:update": "tsx scripts/check-perf.ts --update-baseline",
    "measure:memory": "node --expose-gc --import tsx scripts/measure-memory.ts",
    "lint:no-console": "tsx scripts/check-no-console.ts",
    "lint": "eslint src",
    "schemas": "tsx scripts/export-result-schemas.ts",
    "license:check": "license-checker --production --onlyAllow \"MIT;Apache-2.0;ISC;BSD-2-Clause;BSD-3-Clause;BSD;MPL-2.0;LGPL-3.0-or-later;Unlicense;CC-BY-3.0;CC-BY-4.0;CC0-1.0;0BSD;Apache*;(MIT OR WTFPL);(AFL-2.1 OR BSD-3-Clause);(BSD-2-Clause OR MIT OR Apache-2.0)\"",
    "license:csv": "license-checker --production --csv --out docs/third-party-licenses.csv",
    "sbom": "cyclonedx-npm --output-file sbom.json --omit dev --ignore-npm-errors",
    "docs:api": "typedoc",
    "sync:vendor": "bash scripts/sync-vendor.sh",
    "check:vendor-drift": "tsx scripts/check-vendor-drift.ts",
    "check:vendor-integrity": "tsx scripts/check-vendor-integrity.ts",
    "clean": "rm -rf dist sbom.json docs/api"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "ai-agent",
    "browser-primitives",
    "ai-browser",
    "vendor-agnostic",
    "local-first",
    "playwright",
    "stagehand",
    "claude",
    "computer-use",
    "audit",
    "ux"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.94.0",
    "@browserbasehq/stagehand": "^3.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axe-core": "^4.11.4",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "odiff-bin": "^4.3.8",
    "ora": "^9.4.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.49.0",
    "playwright-core": "^1.49.0",
    "sharp": "^0.34.5",
    "ws": "^8.20.0",
    "yaml": "^2.6.0",
    "zod": "^3.25.76"
  },
  "overrides": {
    "langsmith": "^0.6.0",
    "uuid": "^14.0.0",
    "ip-address": "^10.2.0",
    "hono": "^4.12.21"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.3.0",
    "license-checker": "^25.0.1",
    "nock": "^14.0.14",
    "tsx": "^4.19.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.4",
    "zod-to-json-schema": "^3.25.2"
  }
}
