{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xcodethink/pixelcheck/blob/main/docs/schemas/benchmark-report.schema.json",
  "title": "BenchmarkReport",
  "description": "Aggregate benchmark report (pass@1, by_difficulty, by_tag, durations).",
  "x-result-schema-version": "1.3.0",
  "$ref": "#/definitions/BenchmarkReport",
  "definitions": {
    "BenchmarkReport": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "tag": {
          "type": "string"
        },
        "started_at": {
          "type": "string"
        },
        "finished_at": {
          "type": "string"
        },
        "total_tasks": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "pass_at_1": {
          "type": "number"
        },
        "by_difficulty": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer",
                "minimum": 0
              },
              "passed": {
                "type": "integer",
                "minimum": 0
              },
              "pass_rate": {
                "type": "number"
              }
            },
            "required": [
              "total",
              "passed",
              "pass_rate"
            ],
            "additionalProperties": false
          }
        },
        "by_tag": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "total": {
                "type": "integer",
                "minimum": 0
              },
              "passed": {
                "type": "integer",
                "minimum": 0
              },
              "pass_rate": {
                "type": "number"
              }
            },
            "required": [
              "total",
              "passed",
              "pass_rate"
            ],
            "additionalProperties": false
          }
        },
        "total_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "avg_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "avg_duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "p50_duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "p95_duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "schema_version": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
              },
              "task_id": {
                "type": "string"
              },
              "intent": {
                "type": "string"
              },
              "difficulty": {
                "type": "string",
                "enum": [
                  "easy",
                  "medium",
                  "hard"
                ]
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "passed": {
                "type": "boolean"
              },
              "score": {
                "type": "number"
              },
              "eval_detail": {
                "type": "object",
                "properties": {
                  "passed": {
                    "type": "boolean"
                  },
                  "per_check": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string"
                        },
                        "passed": {
                          "type": "boolean"
                        },
                        "detail": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "passed"
                      ],
                      "additionalProperties": true
                    }
                  },
                  "score": {
                    "type": "number"
                  }
                },
                "required": [
                  "passed",
                  "per_check",
                  "score"
                ],
                "additionalProperties": false
              },
              "cost_usd": {
                "type": "number",
                "minimum": 0
              },
              "duration_ms": {
                "type": "number",
                "minimum": 0
              },
              "final_url": {
                "type": "string"
              },
              "convergence_reason": {
                "type": "string"
              },
              "error": {
                "type": "string"
              }
            },
            "required": [
              "task_id",
              "intent",
              "tags",
              "passed",
              "score",
              "eval_detail",
              "cost_usd",
              "duration_ms",
              "final_url",
              "convergence_reason"
            ],
            "additionalProperties": false
          }
        },
        "config_summary": {
          "type": "object",
          "properties": {
            "cost_mode": {
              "type": "string"
            },
            "planner": {
              "type": "string"
            },
            "navigator": {
              "type": "string"
            },
            "navigator_economy": {
              "type": "string"
            }
          },
          "required": [
            "cost_mode",
            "planner",
            "navigator",
            "navigator_economy"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "tag",
        "started_at",
        "finished_at",
        "total_tasks",
        "passed",
        "pass_at_1",
        "by_difficulty",
        "by_tag",
        "total_cost_usd",
        "avg_cost_usd",
        "avg_duration_ms",
        "p50_duration_ms",
        "p95_duration_ms",
        "tasks",
        "config_summary"
      ],
      "additionalProperties": false
    }
  }
}
