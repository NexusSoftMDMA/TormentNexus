{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xcodethink/pixelcheck/blob/main/docs/schemas/step-result.schema.json",
  "title": "StepResult",
  "description": "Per-step execution record. Includes status, retries, execution_method, and optional signals.",
  "x-result-schema-version": "1.3.0",
  "$ref": "#/definitions/StepResult",
  "definitions": {
    "StepResult": {
      "type": "object",
      "properties": {
        "step_id": {
          "type": "string"
        },
        "step_type": {
          "type": "string",
          "enum": [
            "visit",
            "act",
            "extract",
            "observe",
            "wait_for",
            "assert_visual",
            "assert_dom",
            "assert_a11y",
            "check_email",
            "screenshot",
            "computer_use",
            "custom"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "warn",
            "skip"
          ]
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "screenshot": {
          "type": "string"
        },
        "screenshot_sha256": {
          "type": "string"
        },
        "output": {},
        "error": {
          "type": "string"
        },
        "console_errors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "console",
                  "pageerror",
                  "requestfailed"
                ]
              },
              "text": {
                "type": "string"
              },
              "location": {
                "type": "string"
              },
              "timestamp": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "text",
              "timestamp"
            ],
            "additionalProperties": false
          }
        },
        "retries_used": {
          "type": "integer",
          "minimum": 0
        },
        "execution_method": {
          "type": "string",
          "enum": [
            "stagehand",
            "selector_hint",
            "instruction_mutation",
            "computer_use"
          ]
        },
        "signals": {
          "type": "object",
          "properties": {
            "network": {},
            "performance": {},
            "errors": {},
            "interaction": {}
          },
          "additionalProperties": false
        }
      },
      "required": [
        "step_id",
        "step_type",
        "status",
        "duration_ms",
        "retries_used"
      ],
      "additionalProperties": false
    }
  }
}
