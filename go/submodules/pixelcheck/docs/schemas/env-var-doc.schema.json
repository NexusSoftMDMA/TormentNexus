{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xcodethink/pixelcheck/blob/main/docs/schemas/env-var-doc.schema.json",
  "title": "EnvVarDoc",
  "description": "Documentation for one environment variable that influences server behaviour, returned inside ListCapabilitiesResult.env[]. Names secrets but never values; `required: true` is a static dependency declaration, not a presence probe.",
  "x-result-schema-version": "1.3.0",
  "$ref": "#/definitions/EnvVarDoc",
  "definitions": {
    "EnvVarDoc": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": [
            "auth",
            "cache",
            "cost_guard",
            "artifacts",
            "logging",
            "memory",
            "reports"
          ]
        },
        "default": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "description",
        "scope",
        "default",
        "required"
      ],
      "additionalProperties": false
    }
  }
}
