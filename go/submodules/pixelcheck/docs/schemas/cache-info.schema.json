{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xcodethink/pixelcheck/blob/main/docs/schemas/cache-info.schema.json",
  "title": "CacheInfo",
  "description": "Live state of the M9-4 result cache (enabled / ttl_ms_default / path) inside ListCapabilitiesResult.cache. Path is exposed for diagnostics (paths are not secrets); the cache file's contents stay opaque.",
  "x-result-schema-version": "1.3.0",
  "$ref": "#/definitions/CacheInfo",
  "definitions": {
    "CacheInfo": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "ttl_ms_default": {
          "type": "number",
          "minimum": 0
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "ttl_ms_default",
        "path"
      ],
      "additionalProperties": false
    }
  }
}
