{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xcodethink/pixelcheck/blob/main/docs/schemas/diagnose-result.schema.json",
  "title": "DiagnoseResult",
  "description": "MCP tool envelope returned by `diagnose` (PR-E preset / ADR-034). Holistic page-health diagnosis. Captures the URL with eager visual scoring, reads every diagnostics dimension (performance / network / popups / cookies / storage / visual), and returns a commercial-grade structured report: per-finding severity + dimension + confidence + evidence_refs + standards_mapping (Core Web Vitals / WCAG / OWASP / GDPR), a 0-100 overall_health_score, per-dimension drill-down scores, and a CTO-readable executive_summary.",
  "x-result-schema-version": "1.3.0",
  "$ref": "#/definitions/DiagnoseResult",
  "definitions": {
    "DiagnoseResult": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "url_input": {
          "type": "string"
        },
        "url_final": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "loaded_at": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "error"
          ]
        },
        "error": {
          "type": "string"
        },
        "executive_summary": {
          "type": "string"
        },
        "overall_health_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "dimension_scores": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dimension": {
                "type": "string",
                "enum": [
                  "performance",
                  "visual",
                  "whitebox",
                  "security",
                  "accessibility",
                  "seo",
                  "privacy",
                  "cross_cutting"
                ]
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "finding_counts": {
                "type": "object",
                "properties": {
                  "critical": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "high": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "medium": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  },
                  "low": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 0
                  }
                },
                "additionalProperties": false
              },
              "summary": {
                "type": "string"
              }
            },
            "required": [
              "dimension",
              "score",
              "finding_counts",
              "summary"
            ],
            "additionalProperties": false
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": [
                  "critical",
                  "high",
                  "medium",
                  "low"
                ]
              },
              "dimension": {
                "type": "string",
                "enum": [
                  "performance",
                  "visual",
                  "whitebox",
                  "security",
                  "accessibility",
                  "seo",
                  "privacy",
                  "cross_cutting"
                ]
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "root_cause": {
                "type": "string"
              },
              "recommendation": {
                "type": "string"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "value": {
                      "type": "string"
                    },
                    "note": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "path",
                    "value"
                  ],
                  "additionalProperties": false
                },
                "default": []
              },
              "standards_mapping": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "framework": {
                      "type": "string",
                      "minLength": 1
                    },
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "url": {
                      "type": "string"
                    },
                    "label": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "framework",
                    "id"
                  ],
                  "additionalProperties": false
                },
                "default": []
              },
              "affected_location": {
                "type": "string"
              },
              "affected_url": {
                "type": "string"
              },
              "affected_selector": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "severity",
              "dimension",
              "title",
              "description",
              "root_cause",
              "recommendation",
              "confidence"
            ],
            "additionalProperties": false
          }
        },
        "findings_by_dimension": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "propertyNames": {
            "enum": [
              "performance",
              "visual",
              "whitebox",
              "security",
              "accessibility",
              "seo",
              "privacy",
              "cross_cutting"
            ]
          }
        },
        "screenshot": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "sha256": {
                  "type": "string"
                },
                "width": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                },
                "height": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                },
                "bytes": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                }
              },
              "required": [
                "path",
                "sha256"
              ],
              "additionalProperties": false
            },
            {
              "type": "null"
            }
          ]
        },
        "persona_id": {
          "type": "string"
        },
        "artifacts_dir": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "cache": {
          "type": "object",
          "properties": {
            "hit": {
              "type": "boolean"
            },
            "age_ms": {
              "type": "number",
              "minimum": 0
            },
            "key": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            "cost_saved_usd": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": [
            "hit",
            "age_ms",
            "key"
          ],
          "additionalProperties": false
        },
        "diagnostics": {
          "type": "object",
          "properties": {
            "collected_at": {
              "type": "string",
              "enum": [
                "always",
                "on_failure"
              ],
              "default": "always"
            },
            "popups": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "index": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "url": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "body_text": {
                    "type": "string"
                  },
                  "closed": {
                    "type": "boolean"
                  },
                  "last_seen_url": {
                    "type": "string"
                  },
                  "last_seen_title": {
                    "type": "string"
                  }
                },
                "required": [
                  "index",
                  "url",
                  "title",
                  "body_text",
                  "closed"
                ],
                "additionalProperties": false
              }
            },
            "network": {
              "type": "object",
              "properties": {
                "request_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "failure_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "requests": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "url": {
                        "type": "string"
                      },
                      "method": {
                        "type": "string"
                      },
                      "resource_type": {
                        "type": "string"
                      },
                      "status": {
                        "anyOf": [
                          {
                            "type": "integer"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "duration_ms": {
                        "anyOf": [
                          {
                            "type": "number",
                            "minimum": 0
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "size_bytes": {
                        "anyOf": [
                          {
                            "type": "integer",
                            "minimum": 0
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "from_cache": {
                        "type": "boolean"
                      }
                    },
                    "required": [
                      "url",
                      "method",
                      "status",
                      "duration_ms",
                      "size_bytes"
                    ],
                    "additionalProperties": false
                  }
                },
                "failures": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "url": {
                        "type": "string"
                      },
                      "method": {
                        "type": "string"
                      },
                      "resource_type": {
                        "type": "string"
                      },
                      "error_text": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "url",
                      "method",
                      "error_text"
                    ],
                    "additionalProperties": false
                  }
                },
                "truncated_count": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": [
                "request_count",
                "failure_count",
                "requests",
                "failures"
              ],
              "additionalProperties": false
            },
            "cookies": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "domain": {
                    "type": "string"
                  },
                  "path": {
                    "type": "string"
                  },
                  "expires": {
                    "type": "number"
                  },
                  "http_only": {
                    "type": "boolean"
                  },
                  "secure": {
                    "type": "boolean"
                  },
                  "same_site": {
                    "type": "string",
                    "enum": [
                      "Strict",
                      "Lax",
                      "None"
                    ]
                  }
                },
                "required": [
                  "name",
                  "value",
                  "domain",
                  "path",
                  "expires",
                  "http_only",
                  "secure"
                ],
                "additionalProperties": false
              }
            },
            "storage": {
              "type": "object",
              "properties": {
                "local_storage": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "session_storage": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "local_storage_keys": {
                  "type": "integer",
                  "minimum": 0
                },
                "session_storage_keys": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": [
                "local_storage",
                "session_storage",
                "local_storage_keys",
                "session_storage_keys"
              ],
              "additionalProperties": false
            },
            "performance": {
              "type": "object",
              "properties": {
                "lcp_ms": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "cls": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "inp_ms": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "fcp_ms": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "ttfb_ms": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "dom_content_loaded_ms": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "load_ms": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "resources": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "script": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "stylesheet": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "image": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "xhr_or_fetch": {
                      "type": "integer",
                      "minimum": 0
                    }
                  },
                  "required": [
                    "total",
                    "script",
                    "stylesheet",
                    "image",
                    "xhr_or_fetch"
                  ],
                  "additionalProperties": false
                },
                "transfer_bytes": {
                  "type": "number",
                  "minimum": 0
                },
                "window_ms": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "lcp_ms",
                "cls",
                "inp_ms",
                "fcp_ms",
                "ttfb_ms",
                "dom_content_loaded_ms",
                "load_ms",
                "resources",
                "transfer_bytes",
                "window_ms"
              ],
              "additionalProperties": false
            },
            "visual": {
              "type": "object",
              "properties": {
                "scored": {
                  "type": "boolean"
                },
                "skip_reason": {
                  "type": "string",
                  "enum": [
                    "config_off",
                    "no_goal",
                    "no_api_key",
                    "cost_cap",
                    "no_screenshot",
                    "vision_error"
                  ]
                },
                "rubrics": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "aesthetic",
                      "dark_pattern",
                      "custom"
                    ]
                  },
                  "default": []
                },
                "verdicts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "criterion_id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "label": {
                        "type": "string",
                        "minLength": 1
                      },
                      "kind": {
                        "type": "string",
                        "enum": [
                          "aesthetic",
                          "dark_pattern",
                          "custom"
                        ]
                      },
                      "score": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 10
                      },
                      "rationale": {
                        "type": "string"
                      },
                      "evidence": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "default": []
                      }
                    },
                    "required": [
                      "criterion_id",
                      "label",
                      "kind",
                      "score",
                      "rationale"
                    ],
                    "additionalProperties": false
                  },
                  "default": []
                },
                "findings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "severity": {
                        "type": "string",
                        "enum": [
                          "critical",
                          "high",
                          "medium",
                          "low"
                        ]
                      },
                      "criterion_id": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "description": {
                        "type": "string"
                      },
                      "location": {
                        "type": "string"
                      },
                      "recommendation": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "severity",
                      "criterion_id",
                      "description",
                      "recommendation"
                    ],
                    "additionalProperties": false
                  },
                  "default": []
                },
                "overall_score": {
                  "anyOf": [
                    {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 10
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "summary": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "model": {
                  "type": "string"
                },
                "cost_usd": {
                  "type": "number",
                  "minimum": 0,
                  "default": 0
                },
                "duration_ms": {
                  "type": "number",
                  "minimum": 0,
                  "default": 0
                }
              },
              "required": [
                "scored",
                "overall_score",
                "summary"
              ],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "url_input",
        "url_final",
        "title",
        "loaded_at",
        "status",
        "executive_summary",
        "overall_health_score",
        "dimension_scores",
        "findings",
        "findings_by_dimension",
        "screenshot",
        "persona_id",
        "artifacts_dir",
        "model",
        "cost_usd",
        "duration_ms"
      ],
      "additionalProperties": false
    }
  }
}
