{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xcodethink/pixelcheck/blob/main/docs/schemas/audit-run.schema.json",
  "title": "AuditRun",
  "description": "The top-level result of a `runAudit` invocation. Written to audit.json and returned by the audit_url MCP tool's `report_json` artefact.",
  "x-result-schema-version": "1.3.0",
  "$ref": "#/definitions/AuditRun",
  "definitions": {
    "AuditRun": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "run_id": {
          "type": "string"
        },
        "project_name": {
          "type": "string"
        },
        "base_url": {
          "type": "string"
        },
        "started_at": {
          "type": "string"
        },
        "finished_at": {
          "type": "string"
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "scenario_id": {
                "type": "string"
              },
              "scenario_name": {
                "type": "string"
              },
              "persona_id": {
                "type": "string"
              },
              "persona_display_name": {
                "type": "string"
              },
              "started_at": {
                "type": "string"
              },
              "finished_at": {
                "type": "string"
              },
              "duration_ms": {
                "type": "number",
                "minimum": 0
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "pass_with_issues",
                  "fail"
                ]
              },
              "fingerprint_id": {
                "type": "string"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "step_id": {
                      "type": "string"
                    },
                    "step_type": {
                      "type": "string",
                      "enum": [
                        "visit",
                        "act",
                        "extract",
                        "observe",
                        "wait_for",
                        "assert_visual",
                        "assert_dom",
                        "assert_a11y",
                        "check_email",
                        "screenshot",
                        "computer_use",
                        "custom"
                      ]
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "pass",
                        "fail",
                        "warn",
                        "skip"
                      ]
                    },
                    "duration_ms": {
                      "type": "number",
                      "minimum": 0
                    },
                    "screenshot": {
                      "type": "string"
                    },
                    "screenshot_sha256": {
                      "type": "string"
                    },
                    "output": {},
                    "error": {
                      "type": "string"
                    },
                    "console_errors": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "enum": [
                              "console",
                              "pageerror",
                              "requestfailed"
                            ]
                          },
                          "text": {
                            "type": "string"
                          },
                          "location": {
                            "type": "string"
                          },
                          "timestamp": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "type",
                          "text",
                          "timestamp"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "retries_used": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "execution_method": {
                      "type": "string",
                      "enum": [
                        "stagehand",
                        "selector_hint",
                        "instruction_mutation",
                        "computer_use"
                      ]
                    },
                    "signals": {
                      "type": "object",
                      "properties": {
                        "network": {},
                        "performance": {},
                        "errors": {},
                        "interaction": {}
                      },
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "step_id",
                    "step_type",
                    "status",
                    "duration_ms",
                    "retries_used"
                  ],
                  "additionalProperties": false
                }
              },
              "scores": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "dimension": {
                      "type": "string"
                    },
                    "score": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 10
                    },
                    "justification": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "dimension",
                    "score",
                    "justification"
                  ],
                  "additionalProperties": false
                }
              },
              "overall_score": {
                "type": "number"
              },
              "issues": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "severity": {
                      "type": "string",
                      "enum": [
                        "critical",
                        "high",
                        "medium",
                        "low"
                      ]
                    },
                    "step_id": {
                      "type": "string"
                    },
                    "dimension": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "screenshot": {
                      "type": "string"
                    },
                    "recommendation": {
                      "type": "string"
                    },
                    "wcag_level": {
                      "type": "string",
                      "enum": [
                        "A",
                        "AA",
                        "AAA"
                      ]
                    },
                    "wcag_criterion": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "severity",
                    "description",
                    "recommendation"
                  ],
                  "additionalProperties": false
                }
              },
              "artifacts": {
                "type": "object",
                "properties": {
                  "video": {
                    "type": "string"
                  },
                  "har": {
                    "type": "string"
                  },
                  "console_log": {
                    "type": "string"
                  },
                  "storage_state": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "cost_usd": {
                "type": "number",
                "minimum": 0
              },
              "agent_summary": {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string",
                    "const": "autonomous"
                  },
                  "plan_count": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "total_actions": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "criteria_met": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "criteria_missed": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "convergence_reason": {
                    "type": "string",
                    "enum": [
                      "goal_met",
                      "budget_exceeded",
                      "max_actions",
                      "max_replans",
                      "no_progress",
                      "error"
                    ]
                  }
                },
                "required": [
                  "mode",
                  "plan_count",
                  "total_actions",
                  "criteria_met",
                  "criteria_missed",
                  "convergence_reason"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "scenario_id",
              "scenario_name",
              "persona_id",
              "persona_display_name",
              "started_at",
              "finished_at",
              "duration_ms",
              "status",
              "fingerprint_id",
              "steps",
              "scores",
              "overall_score",
              "issues",
              "artifacts",
              "cost_usd"
            ],
            "additionalProperties": false
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "total": {
              "type": "integer",
              "minimum": 0
            },
            "pass": {
              "type": "integer",
              "minimum": 0
            },
            "pass_with_issues": {
              "type": "integer",
              "minimum": 0
            },
            "fail": {
              "type": "integer",
              "minimum": 0
            },
            "total_cost_usd": {
              "type": "number",
              "minimum": 0
            },
            "total_issues": {
              "type": "integer",
              "minimum": 0
            },
            "critical_issues": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "total",
            "pass",
            "pass_with_issues",
            "fail",
            "total_cost_usd",
            "total_issues",
            "critical_issues"
          ],
          "additionalProperties": false
        },
        "config": {
          "type": "object",
          "properties": {
            "project_name": {
              "type": "string"
            },
            "base_url": {
              "type": "string",
              "format": "uri"
            },
            "admin_url": {
              "type": "string",
              "format": "uri"
            },
            "default_concurrency": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 3
            },
            "default_timeout_ms": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 30000
            },
            "default_locale": {
              "type": "string",
              "enum": [
                "en",
                "zh-CN",
                "ja",
                "es",
                "de"
              ],
              "default": "en"
            },
            "models": {
              "type": "object",
              "properties": {
                "default": {
                  "type": "string",
                  "default": "claude-sonnet-4-6"
                },
                "critic": {
                  "type": "string",
                  "default": "claude-sonnet-4-6"
                },
                "computer_use": {
                  "type": "string",
                  "default": "claude-opus-4-6"
                },
                "planner": {
                  "type": "string",
                  "default": "claude-opus-4-6"
                },
                "navigator": {
                  "type": "string",
                  "default": "claude-sonnet-4-6"
                },
                "replan": {
                  "type": "string",
                  "default": "claude-sonnet-4-6"
                },
                "navigator_economy": {
                  "type": "string",
                  "default": "claude-haiku-4-5-20251001"
                }
              },
              "additionalProperties": false,
              "default": {
                "default": "claude-sonnet-4-6",
                "critic": "claude-sonnet-4-6",
                "computer_use": "claude-opus-4-6",
                "planner": "claude-opus-4-6",
                "navigator": "claude-sonnet-4-6",
                "replan": "claude-sonnet-4-6",
                "navigator_economy": "claude-haiku-4-5-20251001"
              }
            },
            "cost_mode": {
              "type": "string",
              "enum": [
                "max",
                "balanced",
                "economy"
              ],
              "default": "balanced"
            },
            "budget_usd": {
              "type": "number",
              "exclusiveMinimum": 0,
              "default": 3
            },
            "redact_patterns": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "notifications": {
              "type": "object",
              "properties": {
                "slack_webhook_env": {
                  "type": "string"
                },
                "telegram_chat_id_env": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "agent": {
              "type": "object",
              "properties": {
                "default_max_actions": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 30
                },
                "default_replan_threshold": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 3
                },
                "default_max_replans": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 3
                },
                "criteria_check_interval": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 3
                },
                "dom_summary_max_elements": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 50
                }
              },
              "additionalProperties": false
            },
            "observer": {
              "type": "object",
              "properties": {
                "port": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 3847
                },
                "stream_fps": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 10
                },
                "persist_events": {
                  "type": "boolean",
                  "default": true
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "project_name",
            "base_url"
          ],
          "additionalProperties": false
        },
        "redact_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "run_id",
        "project_name",
        "base_url",
        "started_at",
        "finished_at",
        "duration_ms",
        "results",
        "summary",
        "config"
      ],
      "additionalProperties": false
    }
  }
}
