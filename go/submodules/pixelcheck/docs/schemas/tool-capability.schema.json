{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xcodethink/pixelcheck/blob/main/docs/schemas/tool-capability.schema.json",
  "title": "ToolCapability",
  "description": "Per-tool descriptor inside ListCapabilitiesResult.tools[]. Mirrors the MCP `tools/list` shape (name / description / kind / input_schema / result_schema) and adds the richer fields that are deliberately not in the spec-level catalog: cacheable, cost_estimate_usd, side_effects, requires.",
  "x-result-schema-version": "1.3.0",
  "$ref": "#/definitions/ToolCapability",
  "definitions": {
    "ToolCapability": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "preset",
            "primitive",
            "meta"
          ]
        },
        "input_schema": {
          "type": "object",
          "additionalProperties": {}
        },
        "result_schema": {
          "type": "string"
        },
        "cacheable": {
          "type": "boolean"
        },
        "cost_estimate_usd": {
          "type": "object",
          "properties": {
            "typical": {
              "type": "number",
              "minimum": 0
            },
            "min": {
              "type": "number",
              "minimum": 0
            },
            "max": {
              "type": "number",
              "minimum": 0
            },
            "unit": {
              "type": "string",
              "enum": [
                "per_call",
                "per_step",
                "per_persona_scenario"
              ]
            },
            "notes": {
              "type": "string"
            }
          },
          "required": [
            "typical",
            "min",
            "max",
            "unit"
          ],
          "additionalProperties": false
        },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "navigation",
              "state_changing",
              "fs_writes_artifacts",
              "fs_writes_history",
              "fs_reads",
              "network_egress"
            ]
          }
        },
        "requires": {
          "type": "object",
          "properties": {
            "api_keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "browser": {
              "type": "boolean"
            },
            "personas_dir": {
              "type": "boolean"
            },
            "scenarios_dir": {
              "type": "boolean"
            }
          },
          "required": [
            "api_keys",
            "browser"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "name",
        "description",
        "kind",
        "input_schema",
        "cacheable",
        "cost_estimate_usd",
        "side_effects",
        "requires"
      ],
      "additionalProperties": false
    }
  }
}
