{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xcodethink/pixelcheck/blob/main/docs/schemas/scenario-run-result.schema.json",
  "title": "ScenarioRunResult",
  "description": "Per-(scenario, persona) execution result — nested under AuditRun.results[].",
  "x-result-schema-version": "1.3.0",
  "$ref": "#/definitions/ScenarioRunResult",
  "definitions": {
    "ScenarioRunResult": {
      "type": "object",
      "properties": {
        "scenario_id": {
          "type": "string"
        },
        "scenario_name": {
          "type": "string"
        },
        "persona_id": {
          "type": "string"
        },
        "persona_display_name": {
          "type": "string"
        },
        "started_at": {
          "type": "string"
        },
        "finished_at": {
          "type": "string"
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "pass_with_issues",
            "fail"
          ]
        },
        "fingerprint_id": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step_id": {
                "type": "string"
              },
              "step_type": {
                "type": "string",
                "enum": [
                  "visit",
                  "act",
                  "extract",
                  "observe",
                  "wait_for",
                  "assert_visual",
                  "assert_dom",
                  "assert_a11y",
                  "check_email",
                  "screenshot",
                  "computer_use",
                  "custom"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "fail",
                  "warn",
                  "skip"
                ]
              },
              "duration_ms": {
                "type": "number",
                "minimum": 0
              },
              "screenshot": {
                "type": "string"
              },
              "screenshot_sha256": {
                "type": "string"
              },
              "output": {},
              "error": {
                "type": "string"
              },
              "console_errors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "console",
                        "pageerror",
                        "requestfailed"
                      ]
                    },
                    "text": {
                      "type": "string"
                    },
                    "location": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type",
                    "text",
                    "timestamp"
                  ],
                  "additionalProperties": false
                }
              },
              "retries_used": {
                "type": "integer",
                "minimum": 0
              },
              "execution_method": {
                "type": "string",
                "enum": [
                  "stagehand",
                  "selector_hint",
                  "instruction_mutation",
                  "computer_use"
                ]
              },
              "signals": {
                "type": "object",
                "properties": {
                  "network": {},
                  "performance": {},
                  "errors": {},
                  "interaction": {}
                },
                "additionalProperties": false
              }
            },
            "required": [
              "step_id",
              "step_type",
              "status",
              "duration_ms",
              "retries_used"
            ],
            "additionalProperties": false
          }
        },
        "scores": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "dimension": {
                "type": "string"
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 10
              },
              "justification": {
                "type": "string"
              }
            },
            "required": [
              "dimension",
              "score",
              "justification"
            ],
            "additionalProperties": false
          }
        },
        "overall_score": {
          "type": "number"
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "severity": {
                "type": "string",
                "enum": [
                  "critical",
                  "high",
                  "medium",
                  "low"
                ]
              },
              "step_id": {
                "type": "string"
              },
              "dimension": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "screenshot": {
                "type": "string"
              },
              "recommendation": {
                "type": "string"
              },
              "wcag_level": {
                "type": "string",
                "enum": [
                  "A",
                  "AA",
                  "AAA"
                ]
              },
              "wcag_criterion": {
                "type": "string"
              }
            },
            "required": [
              "severity",
              "description",
              "recommendation"
            ],
            "additionalProperties": false
          }
        },
        "artifacts": {
          "type": "object",
          "properties": {
            "video": {
              "type": "string"
            },
            "har": {
              "type": "string"
            },
            "console_log": {
              "type": "string"
            },
            "storage_state": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "agent_summary": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "const": "autonomous"
            },
            "plan_count": {
              "type": "integer",
              "minimum": 0
            },
            "total_actions": {
              "type": "integer",
              "minimum": 0
            },
            "criteria_met": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "criteria_missed": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "convergence_reason": {
              "type": "string",
              "enum": [
                "goal_met",
                "budget_exceeded",
                "max_actions",
                "max_replans",
                "no_progress",
                "error"
              ]
            }
          },
          "required": [
            "mode",
            "plan_count",
            "total_actions",
            "criteria_met",
            "criteria_missed",
            "convergence_reason"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "scenario_id",
        "scenario_name",
        "persona_id",
        "persona_display_name",
        "started_at",
        "finished_at",
        "duration_ms",
        "status",
        "fingerprint_id",
        "steps",
        "scores",
        "overall_score",
        "issues",
        "artifacts",
        "cost_usd"
      ],
      "additionalProperties": false
    }
  }
}
