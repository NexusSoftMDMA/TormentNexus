# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Default models (override in your project's config.yaml if needed)
AUDIT_MODEL_DEFAULT=claude-sonnet-4-6
AUDIT_MODEL_CRITIC=claude-sonnet-4-6
AUDIT_MODEL_COMPUTER_USE=claude-opus-4-6

# Test accounts (Google OAuth dedicated test accounts — never real users)
TEST_GOOGLE_US=audit-us@example.test
TEST_GOOGLE_US_PASSWORD=
TEST_GOOGLE_JP=audit-jp@example.test
TEST_GOOGLE_JP_PASSWORD=
TEST_GOOGLE_DE=audit-de@example.test
TEST_GOOGLE_DE_PASSWORD=
TEST_GOOGLE_CN=audit-cn@example.test
TEST_GOOGLE_CN_PASSWORD=

# Stripe (TEST MODE ONLY — code refuses pk_live_)
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_
STRIPE_TEST_CARD_NUMBER=4242424242424242
STRIPE_TEST_CARD_EXP=12/30
STRIPE_TEST_CARD_CVC=123

# Admin access (read-only audit cookie for your app's admin UI)
ADMIN_COOKIE=

# Optional: residential proxies per region
PROXY_US=
PROXY_JP=
PROXY_DE=
PROXY_CN=
PROXY_BR=
PROXY_SA=

# Optional: notifications
SLACK_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Budget cap for a single run (USD)
MAX_RUN_BUDGET=3.00

# Mail.tm temp inbox API base
MAIL_TM_BASE=https://api.mail.tm
